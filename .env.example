# Database
# For production (Neon free tier), append connection pool params:
DATABASE_URL=postgresql://user:password@host:5432/dbname?connection_limit=5&pool_timeout=10
DIRECT_URL=postgresql://user:password@host:5432/dbname

# Super Admin Credentials (for initial seed)
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=change_this_password
SUPER_ADMIN_NAME=Super Admin

# JWT
# Use a strong random value (32+ chars)
JWT_SECRET=replace_with_a_strong_random_secret_32_chars_minimum
# Alternate env names also accepted by the API:
# JWT_SECRET_KEY=replace_with_a_strong_random_secret_32_chars_minimum
# AUTH_JWT_SECRET=replace_with_a_strong_random_secret_32_chars_minimum
# AUTH_SECRET=replace_with_a_strong_random_secret_32_chars_minimum
JWT_EXPIRES_IN=7d

# OAuth - Google (optional - get from https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# OAuth - GitHub (optional - get from https://github.com/settings/developers)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5001

# Cloudinary (Image hosting - get from https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Brevo Email Service (get from https://app.brevo.com/settings/keys/api)
# Used for: welcome emails, event notifications, announcement notifications
BREVO_API_KEY=your_brevo_api_key
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Your Club Name

# Node Environment
NODE_ENV=development
ENABLE_DEV_AUTH=false
PORT=5001
INVITE_LINK_WH=whatsapp_invite_link

# Render free tier memory tuning
# Set NODE_OPTIONS=--max-old-space-size=400 in Render dashboard environment variables

# Database connection pool (Neon free tier: max ~10 connections)
# Append ?connection_limit=5&pool_timeout=10 to DATABASE_URL for production
