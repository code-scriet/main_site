# Package manager lock files (optional - uncomment if needed)
# package-lock.json
# pnpm-lock.yaml
# yarn.lock

# Documentation artifacts (keep source, ignore builds)
docs/build/

# Build-time SEO artifacts (regenerated by scripts/generate-sitemap.js on every build).
# Committing this file freezes detail-page URLs out of the sitemap whenever the
# build can't reach the API and falls back to the static-pages-only version.
apps/web/public/sitemap.xml

# Backup files from editor auto-saves
*~
*.swp
*.swo
*.orig

# Image thumbnails
._*

# Deployment specific
.Deployment.md
Dockerfile.backup
*.backup.*

# Recipient/export spreadsheets — these regularly contain names + emails (PII).
# Quiz-import fixtures live under tmp/ or are uploaded at runtime, never committed.
*.csv
*.xlsx

# WhatsApp/Social media images accidentally committed
# Exclude logo files from this rule
WhatsApp*
!**/logo.*
!**/public/logo.*
Screenshot*

# Local development files
.local/
.history/
.qoder/
.codex/



# Temporary files
# NOTE: do NOT use a blanket `*.md` here — it silently untracks governance docs
# (SECURITY.md, CONTRIBUTING.md, CODE_OF_CONDUCT.md, ADRs). Ignore only the
# known-local scratch files below. Markdown under tmp/ is already covered by the
# `tmp/` rule above.
html.html

# Local design briefs (handed to Claude Design — never committed)
prompt.md

# Local scratch & design references (previously hidden by the blanket *.md rule).
# These are per-developer working files, not part of the published project.
docs/notes/
apps/web/design-ref/

# Personal/per-machine Claude Code config (keep local; never commit)
.claude/settings.local.json
.claude/skills/

# design-sync (claude.ai/design) — build artifacts & machine state (durable inputs are committed)
.ds-sync/
ds-bundle/
.design-sync/.cache/
.design-sync/learnings/
.design-sync/node_modules/
apps/web/.ds-styles.css
apps/web/.ds-tw-utils.css

# design tooling — local only, never commit (design-sync workspace + agent skills + .ds-* scratch)
.design-sync/
.agents/
apps/web/.ds-entry.tsx
apps/web/.ds-stubs/
apps/web/.ds-tsconfig.json
apps/web/.ds-tw-input.css
