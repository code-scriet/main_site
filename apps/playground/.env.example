# Playground Configuration
VITE_API_URL=http://localhost:5002

# Execution Server
PORT=5002
NODE_ENV=development
ALLOWED_ORIGIN=http://localhost:5173,http://localhost:5174

# JWT Secret — must match the main API server's JWT_SECRET for shared auth
JWT_SECRET=

# Code execution proxy (Cloudflare Worker)
EXECUTOR_URL=https://codescriet-executor.developer-aary.workers.dev/execute
# Shared secret with the Worker. Set the SAME random value here AND in the
# Worker's environment (Cloudflare dashboard) so the Worker rejects anyone else.
# Leave blank to keep the Worker in legacy Origin-only mode during migration.
EXECUTOR_SECRET=

# Piston API (primary — free, no key needed)
PISTON_API_URL=https://emkc.org/api/v2/piston

# Judge0 API (fallback — requires RapidAPI key)
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=
