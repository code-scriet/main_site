generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Prisma 7: connection URLs live in prisma.config.ts (migrate → DIRECT_URL,
  // non-pooler) and in the runtime driver adapter (lib/prisma.ts → DATABASE_URL,
  // pooler). url/directUrl are no longer permitted in the schema block.
}

// Migration Notes:
// - DIRECT_URL should use the non-pooler connection string to avoid P1002 advisory lock errors
// - DATABASE_URL can use the pooler for application queries

model User {
  id               String   @id @default(uuid())
  name             String
  email            String   @unique
  avatar           String?
  oauthProvider    String?  @map("oauth_provider")
  oauthId          String?  @map("oauth_id")
  role             Role     @default(USER)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  password         String?
  bio              String?
  githubUrl        String?  @map("github_url")
  linkedinUrl      String?  @map("linkedin_url")
  twitterUrl       String?  @map("twitter_url")
  websiteUrl       String?  @map("website_url")
  branch           String?
  course           String?
  phone            String?
  profileCompleted Boolean  @default(false) @map("profile_completed")
  year             String?

  // Login telemetry (admin-deep-control)
  lastLoginAt DateTime? @map("last_login_at")
  lastLoginIp String?   @map("last_login_ip")

  // Auth invalidation — JWT carries tokenVersion claim; force-logout increments this.
  // Legacy tokens (no claim) are treated as version 0 and only rejected when DB > 0.
  tokenVersion Int @default(0) @map("token_version")

  // Materialized QOTD streak — consecutive published-and-not-held QOTD days the user solved on.
  // Days without a published QOTD are transparent (neither extend nor break the streak).
  currentStreak   Int       @default(0) @map("current_streak")
  longestStreak   Int       @default(0) @map("longest_streak")
  longestStreakAt DateTime? @map("longest_streak_at")

  // Soft delete — auth middleware rejects rows with isDeleted=true.
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")

  // Admin-initiated password reset — hashed token + expiry. Consumer endpoint is /api/auth/reset-password.
  passwordResetToken     String?   @unique @map("password_reset_token")
  passwordResetExpiresAt DateTime? @map("password_reset_expires_at")

  // Notification bell unread-cutoff — items in /api/notifications older than this are 'read'.
  // Single timestamp avoids an unbounded per-notification join on the free-tier 512 MB box.
  notificationsReadAt DateTime? @map("notifications_read_at")

  announcements           Announcement[]
  registrations           EventRegistration[]
  hiringApplications      HiringApplication[]
  qotdSubmissions         QOTDSubmission[]
  networkProfile          NetworkProfile?
  teamMember              TeamMember?
  // Quiz relations
  createdQuizzes          Quiz[]
  quizParticipants        QuizParticipant[]
  quizAnswers             QuizAnswer[]
  // Certificate relations
  certificates            Certificate[]
  // Team registration relations
  ledTeams                EventTeam[]                   @relation("teamLeader")
  teamMemberships         EventTeamMember[]             @relation("teamMemberships")
  competitionSubmissions  CompetitionSubmission[]
  competitionAutoSaves    CompetitionAutoSave[]
  createdPolls            Poll[]
  pollVotes               PollVote[]
  pollFeedback            PollFeedback[]
  eventsCreated           Event[]                       @relation("eventCreator")
  invitationsReceived     EventInvitation[]             @relation("InvitationInvitee")
  invitationsSent         EventInvitation[]             @relation("InvitationInviter")
  qotdsCreated            QOTD[]                        @relation("qotdCreator")
  auditLogs               AuditLog[]
  executions              Execution[]
  snippets                Snippet[]
  problemSheets           ProblemSheet[]      @relation("ProblemSheetCreator") // S-09
  playgroundPrefs         UserPlaygroundPrefs?
  playgroundDailyUsage    PlaygroundDailyUsage[]
  playgroundLimitResets   PlaygroundLimitReset[]
  playgroundResetRequests PlaygroundLimitResetRequest[]
  problemsCreated         Problem[]                     @relation("ProblemsCreated")
  problemSubmissions      ProblemSubmission[]
  problemCounters         ProblemSubmissionCounter[]
  blocks                  UserBlock[]
  uploadedImages          UploadedImage[]
  notificationsAuthored   NotificationFeed[]            @relation("NotificationAuthor")

  @@index([role, createdAt(sort: Desc)], map: "users_role_created_at_desc_idx")
  @@index([lastLoginAt(sort: Desc)], map: "users_last_login_at_desc_idx")
  @@index([isDeleted, role], map: "users_is_deleted_role_idx")
  @@map("users")
}

// Settings — singleton (id="default"). Flag usage status (audited 2026-05-13):
//   ACTIVE: hiring* (JoinUsPage), email*Enabled (utils/email.ts category guard),
//     showQOTD/showLeaderboard/showNetwork (dashboard + layout gates),
//     certificatesEnabled/playgroundEnabled/competitionEnabled/problemsEnabled
//     (feature gates), playgroundDailyLimit, emailTestingMode/emailTestRecipients,
//     attendanceJwtSecret/indexNowKey (security env), mailingEnabled, hiringEnabled.
//   ADMIN-UI-ONLY: showAchievements, show_tech_blogs — toggled in AdminSettings
//     but no downstream reader. Kept for future feature gating.
//   Do NOT drop any column without a follow-up code change.
model Settings {
  id                       String   @id @default("default")
  clubName                 String   @default("code.scriet") @map("club_name")
  clubEmail                String   @default("contact@codescriet.com") @map("club_email")
  clubDescription          String   @default("Building tomorrow's problem solvers through collaborative learning and hands-on coding experiences.") @map("club_description")
  registrationOpen         Boolean  @default(true) @map("registration_open")
  maxEventsPerUser         Int      @default(5) @map("max_events_per_user")
  announcementsEnabled     Boolean  @default(true) @map("announcements_enabled")
  updatedAt                DateTime @updatedAt @map("updated_at")
  showAchievements         Boolean  @default(true) @map("show_achievements")
  showLeaderboard          Boolean  @default(false) @map("show_leaderboard")
  showQOTD                 Boolean  @default(true) @map("show_qotd")
  discordUrl               String?  @map("discord_url")
  githubUrl                String?  @map("github_url")
  instagramUrl             String?  @map("instagram_url")
  linkedinUrl              String?  @map("linkedin_url")
  twitterUrl               String?  @map("twitter_url")
  whatsappUrl              String?  @map("whatsapp_url")
  // Public contact page channels. contactPhone drives the "Call us" / WhatsApp
  // card; contactEmails is an admin-managed list of { label, email } shown
  // alongside the primary clubEmail so multiple departments can be reached.
  contactPhone             String?  @map("contact_phone")
  contactEmails            Json?    @map("contact_emails")
  hiringEnabled            Boolean  @default(true) @map("hiring_enabled")
  emailAnnouncementBody    String?  @map("email_announcement_body")
  emailEventBody           String?  @map("email_event_body")
  emailFooterText          String?  @map("email_footer_text")
  emailWelcomeBody         String?  @map("email_welcome_body")
  show_tech_blogs          Boolean  @default(true)
  showNetwork              Boolean  @default(true) @map("show_network")
  emailNetworkVerifiedBody String?  @map("email_network_verified_body")
  emailNetworkRejectedBody String?  @map("email_network_rejected_body")

  // Per-team hiring toggles (only apply when hiringEnabled is true)
  hiringTechnical   Boolean @default(true) @map("hiring_technical")
  hiringDsaChamps   Boolean @default(true) @map("hiring_dsa_champs")
  hiringDesigning   Boolean @default(true) @map("hiring_designing")
  hiringSocialMedia Boolean @default(true) @map("hiring_social_media")
  hiringManagement  Boolean @default(true) @map("hiring_management")
  // A11: current hiring season label stamped onto new applications. Admins bump
  // it to re-open hiring (e.g. "2026-autumn"); previous applicants can apply again.
  hiringCycle       String  @default("2026") @map("hiring_cycle")

  // Mailing system toggle
  mailingEnabled Boolean @default(true) @map("mailing_enabled")

  // Feature toggles (President / Super Admin only)
  certificatesEnabled  Boolean @default(true) @map("certificates_enabled")
  playgroundEnabled    Boolean @default(true) @map("playground_enabled")
  playgroundDailyLimit Int     @default(100) @map("playground_daily_limit")

  // Email notification category toggles
  emailWelcomeEnabled       Boolean @default(true) @map("email_welcome_enabled")
  emailEventCreationEnabled Boolean @default(true) @map("email_event_creation_enabled")
  emailRegistrationEnabled  Boolean @default(true) @map("email_registration_enabled")
  emailAnnouncementEnabled  Boolean @default(true) @map("email_announcement_enabled")
  emailCertificateEnabled   Boolean @default(true) @map("email_certificate_enabled")
  emailReminderEnabled      Boolean @default(true) @map("email_reminder_enabled")
  emailInvitationEnabled    Boolean @default(true) @map("email_invitation_enabled")
  emailPasswordResetEnabled Boolean @default(true) @map("email_password_reset_enabled")
  emailPasswordResetBody    String? @map("email_password_reset_body")

  // Email testing mode
  emailTestingMode    Boolean @default(false) @map("email_testing_mode")
  emailTestRecipients String? @map("email_test_recipients")

  // Privileged security env references (super admin / president only)
  attendanceJwtSecret String? @map("attendance_jwt_secret")
  indexNowKey         String? @map("indexnow_key")

  // Competition feature toggle
  competitionEnabled Boolean @default(false) @map("competition_enabled")
  problemsEnabled    Boolean @default(false) @map("problems_enabled")

  // Dashboard v2 — admin-controlled accent token applied to <html data-accent="…">.
  // Allowed values: rust | teal | indigo | violet | mint | mono. Default rust.
  accentColor String @default("rust") @map("accent_color")

  // Admin-selected primary code-execution provider for the judge + playground.
  // Allowed values: wandbox | godbolt. Default wandbox. The CF Worker tries this
  // provider first and transparently falls back to the other on an infra failure
  // (or a language godbolt can't run, e.g. Node/JS). See CLAUDE.md → Execution Resilience.
  codeExecutionProvider String @default("wandbox") @map("code_execution_provider")

  // Site launch date — drives the "months since inception" stat on /about.
  siteLaunchDate DateTime @default("2026-01-01T00:00:00Z") @map("site_launch_date")

  @@map("settings")
}

model Event {
  id                    String      @id @default(uuid())
  title                 String
  description           String
  status                EventStatus @default(UPCOMING)
  startDate             DateTime    @map("start_date")
  endDate               DateTime?   @map("end_date")
  location              String?
  capacity              Int?
  imageUrl              String?     @map("image_url")
  createdBy             String      @map("created_by")
  createdAt             DateTime    @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")
  eventType             String?     @map("event_type")
  prerequisites         String?
  registrationEndDate   DateTime?   @map("registration_end_date")
  registrationStartDate DateTime?   @map("registration_start_date")
  registrationFields    Json?       @map("registration_fields")
  venue                 String?
  agenda                String?
  faqs                  Json?
  featured              Boolean     @default(false)
  highlights            String?
  imageGallery          Json?       @map("image_gallery")
  learningOutcomes      String?     @map("learning_outcomes")
  resources             Json?
  shortDescription      String?     @map("short_description") @db.VarChar(300)
  speakers              Json?
  tags                  String[]    @default([])
  targetAudience        String?     @map("target_audience")
  videoUrl              String?     @map("video_url")
  slug                  String      @unique @default("")
  allowLateRegistration Boolean     @default(false) @map("allow_late_registration")
  remindersEnabled      Boolean     @default(true) @map("reminders_enabled")
  eventDays             Int         @default(1) @map("event_days")
  dayLabels             Json?       @map("day_labels")
  // S-10: per-event reservation marker — set once when the post-event feedback
  // request goes out, so the 6h scheduler tick never re-sends.
  feedbackSentAt        DateTime?   @map("feedback_sent_at")

  // Team registration fields
  teamRegistration Boolean @default(false) @map("team_registration")
  teamMinSize      Int     @default(1) @map("team_min_size")
  teamMaxSize      Int     @default(4) @map("team_max_size")

  registrations     EventRegistration[]
  invitations       EventInvitation[]
  certificates      Certificate[]
  teams             EventTeam[]
  competitionRounds CompetitionRound[]
  feedbackPolls     Poll[]              @relation("EventFeedbackPoll") // S-10
  creator           User                @relation("eventCreator", fields: [createdBy], references: [id], onDelete: Restrict)

  @@index([status, startDate])
  @@index([startDate])
  @@index([featured])
  @@map("events")
}

model EventRegistration {
  id                   String           @id @default(uuid())
  userId               String           @map("user_id")
  eventId              String           @map("event_id")
  timestamp            DateTime         @default(now())
  customFieldResponses Json?            @map("custom_field_responses")
  reminderSentAt       DateTime?        @map("reminder_sent_at")
  registrationType     RegistrationType @default(PARTICIPANT) @map("registration_type")

  // Attendance fields
  attendanceToken String?   @unique @map("attendance_token")
  attended        Boolean   @default(false)
  scannedAt       DateTime? @map("scanned_at")
  manualOverride  Boolean   @default(false) @map("manual_override")

  event          Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamMember     EventTeamMember?
  invitation     EventInvitation? @relation("InvitationToRegistration")
  dayAttendances DayAttendance[]

  @@unique([userId, eventId])
  @@index([eventId, attended])
  @@index([eventId, registrationType, attended])
  @@index([eventId, timestamp(sort: Desc)], map: "event_registrations_event_id_timestamp_desc_idx")
  @@index([userId, timestamp])
  @@index([timestamp])
  @@index([reminderSentAt])
  @@map("event_registrations")
}

model EventInvitation {
  id      String @id @default(uuid())
  eventId String @map("event_id")
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  inviteeUserId String? @map("invitee_user_id")
  inviteeUser   User?   @relation("InvitationInvitee", fields: [inviteeUserId], references: [id], onDelete: Cascade)
  inviteeEmail  String? @map("invitee_email") @db.VarChar(255)

  inviteeNameSnapshot        String? @map("invitee_name_snapshot") @db.VarChar(200)
  inviteeDesignationSnapshot String? @map("invitee_designation_snapshot") @db.VarChar(200)
  inviteeCompanySnapshot     String? @map("invitee_company_snapshot") @db.VarChar(200)

  role          String           @default("Guest") @db.VarChar(50)
  customMessage String?          @map("custom_message") @db.Text
  status        InvitationStatus @default(PENDING)

  certificateEnabled Boolean  @default(true) @map("certificate_enabled")
  certificateType    CertType @default(SPEAKER) @map("certificate_type")

  invitedById       String    @map("invited_by_id")
  invitedBy         User      @relation("InvitationInviter", fields: [invitedById], references: [id], onDelete: Restrict)
  invitedAt         DateTime  @default(now()) @map("invited_at")
  respondedAt       DateTime? @map("responded_at")
  revokedAt         DateTime? @map("revoked_at")
  emailSent         Boolean   @default(false) @map("email_sent")
  emailSentAt       DateTime? @map("email_sent_at")
  lastEmailResentAt DateTime? @map("last_email_resent_at")

  registrationId String?            @unique @map("registration_id")
  registration   EventRegistration? @relation("InvitationToRegistration", fields: [registrationId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([eventId, inviteeUserId])
  @@index([inviteeUserId, status])
  @@index([inviteeEmail, status])
  @@index([eventId, status])
  @@map("event_invitations")
}

model DayAttendance {
  id             String            @id @default(uuid())
  registrationId String            @map("registration_id")
  registration   EventRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  dayNumber      Int               @map("day_number")
  attended       Boolean           @default(false)
  scannedAt      DateTime?         @map("scanned_at")
  scannedBy      String?           @map("scanned_by")
  manualOverride Boolean           @default(false) @map("manual_override")
  createdAt      DateTime          @default(now()) @map("created_at")

  @@unique([registrationId, dayNumber])
  @@map("day_attendances")
}

// Team Registration Models
model EventTeam {
  id         String   @id @default(uuid())
  eventId    String   @map("event_id")
  teamName   String   @map("team_name") @db.VarChar(100)
  inviteCode String   @unique @map("invite_code") @db.VarChar(8)
  leaderId   String   @map("leader_id")
  isLocked   Boolean  @default(false) @map("is_locked")
  createdAt  DateTime @default(now()) @map("created_at")

  event                  Event                   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  leader                 User                    @relation("teamLeader", fields: [leaderId], references: [id], onDelete: Restrict)
  members                EventTeamMember[]
  competitionSubmissions CompetitionSubmission[]
  competitionAutoSaves   CompetitionAutoSave[]

  @@unique([eventId, teamName])
  @@map("event_teams")
}

model EventTeamMember {
  id             String   @id @default(uuid())
  teamId         String   @map("team_id")
  userId         String   @map("user_id")
  registrationId String   @unique @map("registration_id")
  role           EventTeamMemberRole @default(MEMBER)
  joinedAt       DateTime @default(now()) @map("joined_at")

  team         EventTeam         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user         User              @relation("teamMemberships", fields: [userId], references: [id], onDelete: Cascade)
  registration EventRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("event_team_members")
}

model CompetitionRound {
  id               String                      @id @default(uuid())
  eventId          String                      @map("event_id")
  title            String                      @db.VarChar(200)
  description      String?                     @db.Text
  duration         Int
  status           CompetitionStatus           @default(DRAFT)
  roundType        CompetitionRoundType        @default(IMAGE_TARGET) @map("round_type")
  participantScope CompetitionParticipantScope @default(ALL) @map("participant_scope")
  leadersOnly      Boolean                     @default(false) @map("leaders_only")
  allowedTeamIds   String[]                    @default([]) @map("allowed_team_ids")
  targetImageUrl   String?                     @map("target_image_url")
  startedAt        DateTime?                   @map("started_at")
  lockedAt         DateTime?                   @map("locked_at")
  createdAt        DateTime                    @default(now()) @map("created_at")
  updatedAt        DateTime                    @updatedAt @map("updated_at")

  event       Event                     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  submissions CompetitionSubmission[]
  autoSaves   CompetitionAutoSave[]
  problems    CompetitionRoundProblem[]

  @@index([eventId])
  @@index([status, startedAt])
  @@map("competition_rounds")
}

model CompetitionSubmission {
  id           String   @id @default(uuid())
  roundId      String   @map("round_id")
  teamId       String?  @map("team_id")
  userId       String   @map("user_id")
  code         String   @db.Text
  submittedAt  DateTime @default(now()) @map("submitted_at")
  isAutoSubmit Boolean  @default(false) @map("is_auto_submit")
  score        Float?
  rank         Int?
  adminNotes   String?  @map("admin_notes") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  round CompetitionRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  team  EventTeam?       @relation(fields: [teamId], references: [id], onDelete: SetNull)
  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  // PostgreSQL treats NULL as distinct in unique constraints, so this only applies to team submissions.
  @@unique([roundId, teamId])
  @@unique([roundId, userId])
  @@index([teamId])
  @@index([rank, score])
  @@map("competition_submissions")
}

model CompetitionAutoSave {
  id      String   @id @default(uuid())
  roundId String   @map("round_id")
  teamId  String?  @map("team_id")
  userId  String   @map("user_id")
  code    String   @db.Text
  savedAt DateTime @default(now()) @map("saved_at")

  round CompetitionRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  team  EventTeam?       @relation(fields: [teamId], references: [id], onDelete: SetNull)
  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roundId, userId])
  @@index([teamId])
  @@map("competition_auto_saves")
}

model Announcement {
  id               String               @id @default(uuid())
  title            String
  body             String
  priority         AnnouncementPriority @default(MEDIUM)
  createdBy        String               @map("created_by")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  attachments      Json?
  expiresAt        DateTime?            @map("expires_at")
  featured         Boolean              @default(false)
  imageGallery     Json?                @map("image_gallery")
  imageUrl         String?              @map("image_url")
  links            Json?
  pinned           Boolean              @default(false)
  shortDescription String?              @map("short_description") @db.VarChar(300)
  slug             String               @unique @default("")
  tags             String[]             @default([])
  creator          User                 @relation(fields: [createdBy], references: [id], onDelete: Restrict)

  @@index([createdAt])
  @@index([featured])
  @@index([pinned(sort: Desc), createdAt(sort: Desc)], map: "announcements_pinned_created_at_desc_idx")
  @@index([expiresAt, pinned(sort: Desc), createdAt(sort: Desc)], map: "announcements_expires_pinned_created_idx")
  @@map("announcements")
}

model Poll {
  id                   String         @id @default(uuid())
  question             String         @db.VarChar(500)
  description          String?        @db.Text
  slug                 String         @unique
  allowMultipleChoices Boolean        @default(false) @map("allow_multiple_choices")
  allowVoteChange      Boolean        @default(true) @map("allow_vote_change")
  isAnonymous          Boolean        @default(false) @map("is_anonymous")
  deadline             DateTime?
  isPublished          Boolean        @default(true) @map("is_published")
  createdBy            String         @map("created_by")
  // S-10: optional link making this poll the post-event feedback poll for an event.
  eventId              String?        @map("event_id")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")
  creator              User           @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  event                Event?         @relation("EventFeedbackPoll", fields: [eventId], references: [id], onDelete: SetNull)
  options              PollOption[]
  votes                PollVote[]
  feedbackEntries      PollFeedback[]

  @@index([createdBy])
  @@index([isPublished, createdAt(sort: Desc)], map: "polls_published_created_at_desc_idx")
  @@index([deadline, isPublished], map: "polls_deadline_published_idx")
  @@index([eventId])
  @@map("polls")
}

model PollOption {
  id         String              @id @default(uuid())
  pollId     String              @map("poll_id")
  text       String              @db.VarChar(240)
  sortOrder  Int                 @map("sort_order")
  createdAt  DateTime            @default(now()) @map("created_at")
  poll       Poll                @relation(fields: [pollId], references: [id], onDelete: Cascade)
  selections PollVoteSelection[]

  @@unique([pollId, sortOrder])
  @@map("poll_options")
}

model PollVote {
  id         String              @id @default(uuid())
  pollId     String              @map("poll_id")
  userId     String              @map("user_id")
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")
  poll       Poll                @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  selections PollVoteSelection[]

  @@unique([pollId, userId])
  @@index([userId])
  @@map("poll_votes")
}

model PollVoteSelection {
  voteId   String     @map("vote_id")
  optionId String     @map("option_id")
  vote     PollVote   @relation(fields: [voteId], references: [id], onDelete: Cascade)
  option   PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@id([voteId, optionId])
  @@index([optionId])
  @@map("poll_vote_selections")
}

model PollFeedback {
  id        String   @id @default(uuid())
  pollId    String   @map("poll_id")
  userId    String   @map("user_id")
  message   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  poll      Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId])
  @@index([pollId, createdAt(sort: Desc)], map: "poll_feedback_poll_created_at_desc_idx")
  @@index([userId])
  @@map("poll_feedback")
}

