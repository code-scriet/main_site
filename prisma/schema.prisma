model QOTD {
  id          String           @id @default(uuid())
  date        DateTime         @unique
  question    String
  problemLink String           @map("problem_link")
  difficulty  Difficulty
  problemId   String?          @map("problem_id")
  createdById String?          @map("created_by_id")
  createdAt   DateTime         @default(now()) @map("created_at")
  isPublished Boolean          @default(false) @map("is_published")
  publishAt   DateTime?        @map("publish_at")
  publishedAt DateTime?        @map("published_at")
  heldBy      String?          @map("held_by")
  holdReason  String?          @map("hold_reason")
  // Admin "reopen a past QOTD" — when set, the QOTD accepts submissions again via a
  // private signed link even though its date has passed (streak/marks count normally).
  // null = closed/never-reopened. reopenedBy is a plain-string actor snapshot.
  reopenedAt  DateTime?        @map("reopened_at")
  reopenedBy  String?          @map("reopened_by")
  creator     User?            @relation("qotdCreator", fields: [createdById], references: [id], onDelete: SetNull)
