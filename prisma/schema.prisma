// ──────────────── Signatories ────────────────

model Signatory {
  id           String   @id @default(cuid())
  name         String
  title        String   @default("Club President")
  signatureUrl String?  @map("signature_url") // Cloudinary URL or base64 data URI of transparent-bg PNG
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  certificatesAsPrimary Certificate[] @relation("PrimarySignatory")
  certificatesAsFaculty Certificate[] @relation("FacultySignatory")

  @@map("signatories")
}

// ──────────────── Certificate System ────────────────

enum CertType {
  PARTICIPATION
  COMPLETION
  WINNER
  SPEAKER
}

// A4: certificate render template + email delivery template. Lowercase members
// preserve the exact strings already stored (gold/dark/white/emerald and
// default/faculty_distribution) so the USING cast is a no-op rename.
enum CertTemplate {
  gold
  dark
  white
  emerald
}

enum CertEmailTemplate {
  default
  faculty_distribution
}

model Certificate {
  id     String @id @default(cuid())
  certId String @unique @map("cert_id") // Public human-readable ID e.g. "ABCD-EFGH-IJKL"

  recipientId String? @map("recipient_id")
  recipient   User?   @relation(fields: [recipientId], references: [id], onDelete: SetNull)

  recipientName  String @map("recipient_name")
  recipientEmail String @map("recipient_email")

  eventId   String? @map("event_id")
  event     Event?  @relation(fields: [eventId], references: [id], onDelete: SetNull)
  eventName String  @map("event_name")

  type        CertType
  position    String? // e.g. "1st Place" — only for WINNER type
  domain      String? // e.g. "Web Development"
  description String? // Optional description rendered on the certificate

  template CertTemplate @default(gold)

  pdfUrl String? @map("pdf_url")

  // Signatory — snapshot denormalized at generation time for historical accuracy
  signatoryId       String?    @map("signatory_id")
  signatory         Signatory? @relation("PrimarySignatory", fields: [signatoryId], references: [id], onDelete: SetNull)
  signatoryName     String?    @map("signatory_name") // denormalized
  signatoryTitle    String?    @map("signatory_title") // denormalized
  signatoryImageUrl String?    @map("signatory_image_url") // denormalized (Cloudinary URL)

  // Faculty signatory — optional second signer
  facultySignatoryId       String?    @map("faculty_signatory_id")
  facultySignatory         Signatory? @relation("FacultySignatory", fields: [facultySignatoryId], references: [id], onDelete: SetNull)
  facultyName              String?    @map("faculty_name")
  facultyTitle             String?    @map("faculty_title")
  facultySignatoryImageUrl String?    @map("faculty_signatory_image_url")

  issuedBy String   @map("issued_by")
  issuedAt DateTime @default(now()) @map("issued_at")

  emailSent   Boolean   @default(false) @map("email_sent")
  emailSentAt DateTime? @map("email_sent_at")

  lastEmailResentAt DateTime? @map("last_email_resent_at")

  // Email delivery template chosen at generation time, so resend replays the same one.
  emailTemplate   CertEmailTemplate @default(default) @map("email_template")
  emailSignerName String? @map("email_signer_name") // signer name for the faculty_distribution email

  isRevoked     Boolean   @default(false) @map("is_revoked")
  revokedAt     DateTime? @map("revoked_at")
  revokedBy     String?   @map("revoked_by")
  revokedReason String?   @map("revoked_reason")

  viewCount Int @default(0) @map("view_count")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([recipientEmail, eventId, type], name: "unique_cert_per_event")
  @@index([recipientId])
  @@index([recipientEmail])
  @@index([eventId, issuedAt])
  @@map("certificates")
}

model Credit {
  id           String      @id @default(uuid())
  title        String
  description  String?     @db.Text
  category     String
  teamMemberId String?     @map("team_member_id")
  teamMember   TeamMember? @relation(fields: [teamMemberId], references: [id], onDelete: SetNull)
  order        Int         @default(0)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  @@index([category, order])
  @@index([teamMemberId])
  @@map("credits")
}

// Dashboard v3 — admin-authored & auto-generated notifications.
// One row per broadcast. Audience is denormalised onto the row so we never
// fan out per-user (free-tier safe). The bell menu unions these into its feed
// alongside the auto-derived items (invitations / certs / quiz / audit).
model NotificationFeed {
  id              String               @id @default(uuid())
  source          NotificationSource   @default(ADMIN)
  audience        NotificationAudience @default(ALL)
  // Roles to target when audience = CUSTOM. JSON: ["USER","NETWORK", ...]
  audienceRoles   Json?                @map("audience_roles")
  // Specific user IDs to target when audience = CUSTOM. JSON string[].
  audienceUserIds Json?                @map("audience_user_ids")
  category        String               @default("system")
  icon            String               @default("bell")
  title           String               @db.VarChar(200)
  body            String?              @db.Text
  link            String?              @db.VarChar(500)
  // Optional reference back to the entity that triggered the notification
  // (e.g. for auto-generated event/problem/announcement broadcasts).
  refEntity       String?              @map("ref_entity")
  refEntityId     String?              @map("ref_entity_id")
  createdById     String?              @map("created_by_id")
  createdBy       User?                @relation("NotificationAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt       DateTime             @default(now()) @map("created_at")
  expiresAt       DateTime?            @map("expires_at")

  @@index([createdAt(sort: Desc)])
  @@index([audience, createdAt(sort: Desc)])
  @@index([refEntity, refEntityId])
  @@map("notification_feed")
}

enum NotificationSource {
  ADMIN
  AUTO_EVENT
  AUTO_ANNOUNCEMENT
  AUTO_PROBLEM
  AUTO_QOTD
  AUTO_QUIZ
  SYSTEM
}

enum NotificationAudience {
  ALL
  USERS
  NETWORK
  ALUMNI
  NETWORK_AND_ALUMNI
  ADMIN
  CORE_MEMBER
  CUSTOM
}

// Dashboard v2 — image library record written on every /api/upload/image POST.
// Powers the upload-history endpoint and the ImageUploadTool gallery.
model UploadedImage {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  url       String
  publicId  String   @unique @map("public_id")
  filename  String?
  bytes     Int?
  width     Int?
  height    Int?
  format    String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt(sort: Desc)])
  @@map("uploaded_images")
}
