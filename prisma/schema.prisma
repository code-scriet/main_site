generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Migration Notes:
// - DIRECT_URL should use the non-pooler connection string to avoid P1002 advisory lock errors
// - DATABASE_URL can use the pooler for application queries

model User {
  id                     String                  @id @default(uuid())
  name                   String
  email                  String                  @unique
  avatar                 String?
  oauthProvider          String?                 @map("oauth_provider")
  oauthId                String?                 @map("oauth_id")
  role                   Role                    @default(USER)
  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @updatedAt @map("updated_at")
  password               String?
  bio                    String?
  githubUrl              String?                 @map("github_url")
  linkedinUrl            String?                 @map("linkedin_url")
  twitterUrl             String?                 @map("twitter_url")
  websiteUrl             String?                 @map("website_url")
  branch                 String?
  course                 String?
  phone                  String?
  profileCompleted       Boolean                 @default(false) @map("profile_completed")
  year                   String?
  announcements          Announcement[]
  registrations          EventRegistration[]
  hiringApplications     HiringApplication[]
  qotdSubmissions        QOTDSubmission[]
  networkProfile         NetworkProfile?
  teamMember             TeamMember?
  // Quiz relations
  createdQuizzes         Quiz[]
  quizParticipants       QuizParticipant[]
  quizAnswers            QuizAnswer[]
  // Certificate relations
  certificates           Certificate[]
  // Team registration relations
  ledTeams               EventTeam[]             @relation("teamLeader")
  teamMemberships        EventTeamMember[]       @relation("teamMemberships")
  competitionSubmissions CompetitionSubmission[]
  competitionAutoSaves   CompetitionAutoSave[]
  createdPolls           Poll[]
  pollVotes              PollVote[]
  pollFeedback           PollFeedback[]
  eventsCreated          Event[]                 @relation("eventCreator")
  qotdsCreated           QOTD[]                  @relation("qotdCreator")
  auditLogs              AuditLog[]
  executions             Execution[]
  snippets               Snippet[]
  playgroundPrefs        UserPlaygroundPrefs?
  playgroundDailyUsage   PlaygroundDailyUsage[]
  playgroundLimitResets  PlaygroundLimitReset[]

  @@index([role, createdAt(sort: Desc)], map: "users_role_created_at_desc_idx")
  @@map("users")
}

model Settings {
  id                       String   @id @default("default")
  clubName                 String   @default("code.scriet") @map("club_name")
  clubEmail                String   @default("contact@codescriet.com") @map("club_email")
  clubDescription          String   @default("Building tomorrow's problem solvers through collaborative learning and hands-on coding experiences.") @map("club_description")
  registrationOpen         Boolean  @default(true) @map("registration_open")
  maxEventsPerUser         Int      @default(5) @map("max_events_per_user")
  announcementsEnabled     Boolean  @default(true) @map("announcements_enabled")
  updatedAt                DateTime @updatedAt @map("updated_at")
  showAchievements         Boolean  @default(true) @map("show_achievements")
  showLeaderboard          Boolean  @default(false) @map("show_leaderboard")
  showQOTD                 Boolean  @default(true) @map("show_qotd")
  discordUrl               String?  @map("discord_url")
  githubUrl                String?  @map("github_url")
  instagramUrl             String?  @map("instagram_url")
  linkedinUrl              String?  @map("linkedin_url")
  twitterUrl               String?  @map("twitter_url")
  hiringEnabled            Boolean  @default(true) @map("hiring_enabled")
  emailAnnouncementBody    String?  @map("email_announcement_body")
  emailEventBody           String?  @map("email_event_body")
  emailFooterText          String?  @map("email_footer_text")
  emailWelcomeBody         String?  @map("email_welcome_body")
  show_tech_blogs          Boolean  @default(true)
  showNetwork              Boolean  @default(true) @map("show_network")
  emailNetworkVerifiedBody String?  @map("email_network_verified_body")
  emailNetworkRejectedBody String?  @map("email_network_rejected_body")

  // Per-team hiring toggles (only apply when hiringEnabled is true)
  hiringTechnical   Boolean @default(true) @map("hiring_technical")
  hiringDsaChamps   Boolean @default(true) @map("hiring_dsa_champs")
  hiringDesigning   Boolean @default(true) @map("hiring_designing")
  hiringSocialMedia Boolean @default(true) @map("hiring_social_media")
  hiringManagement  Boolean @default(true) @map("hiring_management")

  // Mailing system toggle
  mailingEnabled Boolean @default(true) @map("mailing_enabled")

  // Feature toggles (President / Super Admin only)
  certificatesEnabled  Boolean @default(true) @map("certificates_enabled")
  playgroundEnabled    Boolean @default(true) @map("playground_enabled")
  playgroundDailyLimit Int     @default(100) @map("playground_daily_limit")

  // Email notification category toggles
  emailWelcomeEnabled       Boolean @default(true) @map("email_welcome_enabled")
  emailEventCreationEnabled Boolean @default(true) @map("email_event_creation_enabled")
  emailRegistrationEnabled  Boolean @default(true) @map("email_registration_enabled")
  emailAnnouncementEnabled  Boolean @default(true) @map("email_announcement_enabled")
  emailCertificateEnabled   Boolean @default(true) @map("email_certificate_enabled")
  emailReminderEnabled      Boolean @default(true) @map("email_reminder_enabled")

  // Email testing mode
  emailTestingMode    Boolean @default(false) @map("email_testing_mode")
  emailTestRecipients String? @map("email_test_recipients")

  // Privileged security env references (super admin / president only)
  attendanceJwtSecret String? @map("attendance_jwt_secret")
  indexNowKey         String? @map("indexnow_key")

  // Competition feature toggle
  competitionEnabled Boolean @default(false) @map("competition_enabled")

  @@map("settings")
}

model Event {
  id                    String      @id @default(uuid())
  title                 String
  description           String
  status                EventStatus @default(UPCOMING)
  startDate             DateTime    @map("start_date")
  endDate               DateTime?   @map("end_date")
  location              String?
  capacity              Int?
  imageUrl              String?     @map("image_url")
  createdBy             String      @map("created_by")
  createdAt             DateTime    @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")
  eventType             String?     @map("event_type")
  prerequisites         String?
  registrationEndDate   DateTime?   @map("registration_end_date")
  registrationStartDate DateTime?   @map("registration_start_date")
  registrationFields    Json?       @map("registration_fields")
  venue                 String?
  agenda                String?
  faqs                  Json?
  featured              Boolean     @default(false)
  highlights            String?
  imageGallery          Json?       @map("image_gallery")
  learningOutcomes      String?     @map("learning_outcomes")
  resources             Json?
  shortDescription      String?     @map("short_description") @db.VarChar(300)
  speakers              Json?
  tags                  String[]    @default([])
  targetAudience        String?     @map("target_audience")
  videoUrl              String?     @map("video_url")
  slug                  String      @unique @default("")
  allowLateRegistration Boolean     @default(false) @map("allow_late_registration")

  // Team registration fields
  teamRegistration Boolean @default(false) @map("team_registration")
  teamMinSize      Int     @default(1) @map("team_min_size")
  teamMaxSize      Int     @default(4) @map("team_max_size")

  registrations     EventRegistration[]
  certificates      Certificate[]
  teams             EventTeam[]
  competitionRounds CompetitionRound[]
  creator           User                @relation("eventCreator", fields: [createdBy], references: [id], onDelete: Restrict)

  @@index([status, startDate])
  @@index([startDate])
  @@index([featured])
  @@map("events")
}

model EventRegistration {
  id                   String    @id @default(uuid())
  userId               String    @map("user_id")
  eventId              String    @map("event_id")
  timestamp            DateTime  @default(now())
  customFieldResponses Json?     @map("custom_field_responses")
  reminderSentAt       DateTime? @map("reminder_sent_at")

  // Attendance fields
  attendanceToken String?   @unique @map("attendance_token")
  attended        Boolean   @default(false)
  scannedAt       DateTime? @map("scanned_at")
  manualOverride  Boolean   @default(false) @map("manual_override")

  event      Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamMember EventTeamMember?

  @@unique([userId, eventId])
  @@index([eventId])
  @@index([eventId, attended])
  @@index([eventId, timestamp(sort: Desc)], map: "event_registrations_event_id_timestamp_desc_idx")
  @@index([userId, timestamp])
  @@index([timestamp])
  @@index([reminderSentAt])
  @@map("event_registrations")
}

// Team Registration Models
model EventTeam {
  id         String   @id @default(uuid())
  eventId    String   @map("event_id")
  teamName   String   @map("team_name") @db.VarChar(100)
  inviteCode String   @unique @map("invite_code") @db.VarChar(8)
  leaderId   String   @map("leader_id")
  isLocked   Boolean  @default(false) @map("is_locked")
  createdAt  DateTime @default(now()) @map("created_at")

  event                  Event                   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  leader                 User                    @relation("teamLeader", fields: [leaderId], references: [id], onDelete: Restrict)
  members                EventTeamMember[]
  competitionSubmissions CompetitionSubmission[]
  competitionAutoSaves   CompetitionAutoSave[]

  @@unique([eventId, teamName])
  @@index([inviteCode])
  @@index([eventId])
  @@map("event_teams")
}

model EventTeamMember {
  id             String   @id @default(uuid())
  teamId         String   @map("team_id")
  userId         String   @map("user_id")
  registrationId String   @unique @map("registration_id")
  role           String   @default("MEMBER") @db.VarChar(10)
  joinedAt       DateTime @default(now()) @map("joined_at")

  team         EventTeam         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user         User              @relation("teamMemberships", fields: [userId], references: [id], onDelete: Cascade)
  registration EventRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("event_team_members")
}

model CompetitionRound {
  id               String                      @id @default(uuid())
  eventId          String                      @map("event_id")
  title            String                      @db.VarChar(200)
  description      String?                     @db.Text
  duration         Int
  status           CompetitionStatus           @default(DRAFT)
  participantScope CompetitionParticipantScope @default(ALL) @map("participant_scope")
  leadersOnly      Boolean                     @default(false) @map("leaders_only")
  allowedTeamIds   String[]                    @default([]) @map("allowed_team_ids")
  targetImageUrl   String?                     @map("target_image_url")
  startedAt        DateTime?                   @map("started_at")
  lockedAt         DateTime?                   @map("locked_at")
  createdAt        DateTime                    @default(now()) @map("created_at")
  updatedAt        DateTime                    @updatedAt @map("updated_at")

  event       Event                   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  submissions CompetitionSubmission[]
  autoSaves   CompetitionAutoSave[]

  @@index([eventId])
  @@index([status, startedAt])
  @@map("competition_rounds")
}

model CompetitionSubmission {
  id           String   @id @default(uuid())
  roundId      String   @map("round_id")
  teamId       String?  @map("team_id")
  userId       String   @map("user_id")
  code         String   @db.Text
  submittedAt  DateTime @default(now()) @map("submitted_at")
  isAutoSubmit Boolean  @default(false) @map("is_auto_submit")
  score        Float?
  rank         Int?
  adminNotes   String?  @map("admin_notes") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  round CompetitionRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  team  EventTeam?       @relation(fields: [teamId], references: [id], onDelete: SetNull)
  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  // PostgreSQL treats NULL as distinct in unique constraints, so this only applies to team submissions.
  @@unique([roundId, teamId])
  @@unique([roundId, userId])
  @@index([roundId])
  @@index([teamId])
  @@index([rank, score])
  @@map("competition_submissions")
}

model CompetitionAutoSave {
  id      String   @id @default(uuid())
  roundId String   @map("round_id")
  teamId  String?  @map("team_id")
  userId  String   @map("user_id")
  code    String   @db.Text
  savedAt DateTime @default(now()) @map("saved_at")

  round CompetitionRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  team  EventTeam?       @relation(fields: [teamId], references: [id], onDelete: SetNull)
  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roundId, userId])
  @@index([roundId])
  @@index([teamId])
  @@map("competition_auto_saves")
}

model Announcement {
  id               String               @id @default(uuid())
  title            String
  body             String
  priority         AnnouncementPriority @default(MEDIUM)
  createdBy        String               @map("created_by")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  attachments      Json?
  expiresAt        DateTime?            @map("expires_at")
  featured         Boolean              @default(false)
  imageGallery     Json?                @map("image_gallery")
  imageUrl         String?              @map("image_url")
  links            Json?
  pinned           Boolean              @default(false)
  shortDescription String?              @map("short_description") @db.VarChar(300)
  slug             String               @unique @default("")
  tags             String[]             @default([])
  creator          User                 @relation(fields: [createdBy], references: [id], onDelete: Restrict)

  @@index([createdAt])
  @@index([featured])
  @@index([pinned])
  @@index([expiresAt])
  @@index([pinned(sort: Desc), createdAt(sort: Desc)], map: "announcements_pinned_created_at_desc_idx")
  @@index([expiresAt, pinned(sort: Desc), createdAt(sort: Desc)], map: "announcements_expires_pinned_created_idx")
  @@map("announcements")
}

model Poll {
  id                   String         @id @default(uuid())
  question             String         @db.VarChar(500)
  description          String?        @db.Text
  slug                 String         @unique
  allowMultipleChoices Boolean        @default(false) @map("allow_multiple_choices")
  allowVoteChange      Boolean        @default(true) @map("allow_vote_change")
  isAnonymous          Boolean        @default(false) @map("is_anonymous")
  deadline             DateTime?
  isPublished          Boolean        @default(true) @map("is_published")
  createdBy            String         @map("created_by")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")
  creator              User           @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  options              PollOption[]
  votes                PollVote[]
  feedbackEntries      PollFeedback[]

  @@index([createdBy])
  @@index([isPublished, createdAt(sort: Desc)], map: "polls_published_created_at_desc_idx")
  @@index([deadline, isPublished], map: "polls_deadline_published_idx")
  @@map("polls")
}

model PollOption {
  id         String              @id @default(uuid())
  pollId     String              @map("poll_id")
  text       String              @db.VarChar(240)
  sortOrder  Int                 @map("sort_order")
  createdAt  DateTime            @default(now()) @map("created_at")
  poll       Poll                @relation(fields: [pollId], references: [id], onDelete: Cascade)
  selections PollVoteSelection[]

  @@unique([pollId, sortOrder])
  @@index([pollId])
  @@map("poll_options")
}

model PollVote {
  id         String              @id @default(uuid())
  pollId     String              @map("poll_id")
  userId     String              @map("user_id")
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")
  poll       Poll                @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  selections PollVoteSelection[]

  @@unique([pollId, userId])
  @@index([pollId])
  @@index([userId])
  @@map("poll_votes")
}

model PollVoteSelection {
  voteId   String     @map("vote_id")
  optionId String     @map("option_id")
  vote     PollVote   @relation(fields: [voteId], references: [id], onDelete: Cascade)
  option   PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@id([voteId, optionId])
  @@index([optionId])
  @@map("poll_vote_selections")
}

model PollFeedback {
  id        String   @id @default(uuid())
  pollId    String   @map("poll_id")
  userId    String   @map("user_id")
  message   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  poll      Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId])
  @@index([pollId, createdAt(sort: Desc)], map: "poll_feedback_poll_created_at_desc_idx")
  @@index([userId])
  @@map("poll_feedback")
}

model TeamMember {
  id           String   @id @default(uuid())
  name         String
  role         String
  team         String
  imageUrl     String   @map("image_url")
  github       String?
  linkedin     String?
  twitter      String?
  order        Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  instagram    String?
  // Link to User account
  userId       String?  @unique @map("user_id")
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  // URL-friendly slug for profile page
  slug         String?  @unique
  // Legacy slugs kept for backward-compatible URL resolution
  legacySlugs  String[] @default([]) @map("legacy_slugs")
  // Rich content fields for personal page
  bio          String?  @db.Text
  vision       String?  @db.Text
  story        String?  @db.Text
  expertise    String?  @db.Text
  achievements String?  @db.Text
  website      String?
  // Credits given to this team member
  credits      Credit[]

  @@index([team, order])
  @@index([team, order, createdAt], map: "team_members_team_order_created_at_idx")
  @@index([order, createdAt], map: "team_members_order_created_at_idx")
  @@map("team_members")
}

model Achievement {
  id               String   @id @default(uuid())
  title            String
  slug             String   @unique @default("")
  description      String
  content          String?  @db.Text
  shortDescription String?  @map("short_description") @db.VarChar(300)
  eventName        String?  @map("event_name")
  // Free-form attribution text (e.g., person/team/institution), intentionally not a FK.
  achievedBy       String   @map("achieved_by")
  imageUrl         String?  @map("image_url")
  imageGallery     Json?    @map("image_gallery")
  date             DateTime
  tags             String[] @default([])
  featured         Boolean  @default(false)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([date])
  @@index([featured])
  @@index([featured, date(sort: Desc)], map: "achievements_featured_date_desc_idx")
  @@map("achievements")
}

model QOTD {
  id          String           @id @default(uuid())
  date        DateTime         @unique
  question    String
  problemLink String           @map("problem_link")
  difficulty  String
  createdById String?          @map("created_by_id")
  createdAt   DateTime         @default(now()) @map("created_at")
  creator     User?            @relation("qotdCreator", fields: [createdById], references: [id], onDelete: SetNull)
  submissions QOTDSubmission[]

  @@index([createdById])

  @@map("qotd")
}

model QOTDSubmission {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  qotdId    String   @map("qotd_id")
  timestamp DateTime @default(now())
  qotd      QOTD     @relation(fields: [qotdId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, qotdId])
  @@index([qotdId])
  @@index([userId, timestamp])
  @@index([timestamp])
  @@map("qotd_submissions")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  metadata  Json?
  timestamp DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, timestamp])
  @@map("audit_logs")
}

model HiringApplication {
  id           String            @id @default(uuid())
  name         String
  email        String            @unique
  phone        String?
  department   String
  year         String
  skills       String?
  applyingRole ApplyingRole      @map("applying_role")
  status       ApplicationStatus @default(PENDING)
  userId       String?           @map("user_id")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  user         User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([applyingRole, createdAt])
  @@map("hiring_applications")
}

enum Role {
  PUBLIC
  USER
  CORE_MEMBER
  ADMIN
  PRESIDENT
  MEMBER
  NETWORK
}

enum EventStatus {
  UPCOMING
  ONGOING
  PAST
}

enum AnnouncementPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ApplyingRole {
  TECHNICAL
  DSA_CHAMPS
  DESIGNING
  SOCIAL_MEDIA
  MANAGEMENT
}

enum ApplicationStatus {
  PENDING
  INTERVIEW_SCHEDULED
  SELECTED
  REJECTED
}

enum CompetitionStatus {
  DRAFT
  ACTIVE
  LOCKED
  JUDGING
  FINISHED
}

enum CompetitionParticipantScope {
  ALL
  SELECTED_TEAMS
}

// Network Feature - Industry Professionals & Alumni
model NetworkProfile {
  id     String @id @default(cuid())
  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // URL slug (name-XXXX format for unique public URLs)
  slug        String?  @unique
  // Legacy slugs kept for backward-compatible URL resolution
  legacySlugs String[] @default([]) @map("legacy_slugs")

  // Professional details
  fullName     String  @map("full_name")
  designation  String // e.g. "CEO", "Senior Engineer"
  company      String
  industry     String // e.g. "FinTech", "EdTech", "Product"
  bio          String? @db.Text
  profilePhoto String? @map("profile_photo")
  phone        String? // Private — only for admin contact

  // Social/professional links
  linkedinUsername String? @map("linkedin_username")
  twitterUsername  String? @map("twitter_username")
  githubUsername   String? @map("github_username")
  personalWebsite  String? @map("personal_website")

  // Connection context
  connectionType NetworkConnectionType @map("connection_type")
  connectionNote String?               @map("connection_note") @db.Text
  connectedSince Int?                  @map("connected_since") // Year they first connected

  // Alumni-specific fields (only relevant when connectionType is ALUMNI)
  passoutYear     Int?    @map("passout_year") // Graduation year
  degree          String? // e.g. "B.Tech", "M.Tech", "MCA"
  branch          String? // e.g. "Computer Science", "Electronics"
  rollNumber      String? @map("roll_number") // Optional college roll
  achievements    String? @db.Text // Notable achievements
  currentLocation String? @map("current_location") // City, Country

  // Rich personal profile fields (supports Markdown/HTML)
  vision    String? @db.Text // Personal/professional vision
  story     String? @db.Text // Background/journey story
  expertise String? @db.Text // Skills and expertise areas

  // Admin-managed rich content (markdown)
  adminNotes String? @map("admin_notes") @db.Text

  // Event participation history (JSON array of events they attended/hosted)
  // Format: [{ title: string, date: string, description?: string, type?: string, link?: string }]
  events Json? @default("[]")

  // Featured flag for homepage showcase
  isFeatured Boolean @default(false) @map("is_featured")

  // Verification
  status          NetworkStatus @default(PENDING)
  verifiedAt      DateTime?     @map("verified_at")
  verifiedBy      String?       @map("verified_by")
  rejectionReason String?       @map("rejection_reason")

  // Visibility
  isPublic     Boolean @default(true) @map("is_public")
  displayOrder Int     @default(0) @map("display_order")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@index([connectionType])
  @@index([industry])
  @@index([displayOrder])
  @@index([isFeatured])
  @@index([passoutYear])
  @@index([status, isPublic, isFeatured(sort: Desc), displayOrder, createdAt(sort: Desc)], map: "network_profiles_public_feed_idx")
  @@index([status, isPublic, industry], map: "network_profiles_status_public_industry_idx")
  @@map("network_profiles")
}

// ──────────────── Live Quiz System ────────────────

model Quiz {
  id                   String            @id @default(uuid())
  title                String            @db.VarChar(255)
  description          String?           @db.Text
  joinCode             String?           @unique @map("join_code") @db.VarChar(6)
  pin                  String?           @unique @db.VarChar(6)
  pinActive            Boolean           @default(true) @map("pin_active")
  createdBy            String            @map("created_by")
  creator              User              @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  status               QuizStatus        @default(DRAFT)
  currentQuestionIndex Int               @default(-1) @map("current_question_index")
  questionCount        Int               @default(0) @map("question_count")
  totalParticipants    Int               @default(0) @map("total_participants")
  startedAt            DateTime?         @map("started_at")
  endedAt              DateTime?         @map("ended_at")
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")
  questions            QuizQuestion[]
  participants         QuizParticipant[]
  answers              QuizAnswer[]

  @@index([status], map: "idx_quizzes_status")
  @@index([createdBy], map: "idx_quizzes_created_by")
  @@index([pin], map: "idx_quizzes_pin")
  @@map("quizzes")
}

model QuizQuestion {
  id                 String           @id @default(uuid())
  quizId             String           @map("quiz_id")
  quiz               Quiz             @relation(fields: [quizId], references: [id], onDelete: Cascade)
  position           Int
  questionText       String           @map("question_text") @db.Text
  questionType       QuizQuestionType @default(MCQ) @map("question_type")
  options            Json? // string array for mcq/true_false/poll
  correctAnswer      String?          @map("correct_answer")
  timeLimitSeconds   Int              @default(20) @map("time_limit_seconds")
  points             Int              @default(100)
  mediaUrl           String?          @map("media_url")
  totalAnswers       Int              @default(0) @map("total_answers")
  correctCount       Int              @default(0) @map("correct_count")
  avgAnswerTimeMs    Int              @default(0) @map("avg_answer_time_ms")
  answerDistribution Json?            @map("answer_distribution")
  createdAt          DateTime         @default(now()) @map("created_at")
  answers            QuizAnswer[]

  @@index([quizId, position], map: "idx_quiz_questions_quiz_position")
  @@map("quiz_questions")
}

model QuizParticipant {
  id                String   @id @default(uuid())
  quizId            String   @map("quiz_id")
  quiz              Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  userId            String   @map("user_id")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName       String   @map("display_name") @db.VarChar(100)
  joinedAt          DateTime @default(now()) @map("joined_at")
  finalScore        Int      @default(0) @map("final_score")
  finalRank         Int?     @map("final_rank")
  correctCount      Int      @default(0) @map("correct_count")
  totalAnswerTimeMs BigInt   @default(0) @map("total_answer_time_ms")
  joinedMidQuiz     Boolean  @default(false) @map("joined_mid_quiz")
  questionsAnswered Int      @default(0) @map("questions_answered")

  @@unique([quizId, userId])
  @@index([userId], map: "idx_quiz_participants_user_id")
  @@index([quizId], map: "idx_quiz_participants_quiz_id")
  @@map("quiz_participants")
}

model QuizAnswer {
  id              String       @id @default(uuid())
  quizId          String       @map("quiz_id")
  quiz            Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  questionId      String       @map("question_id")
  question        QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  userId          String       @map("user_id")
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  answerSubmitted String?      @map("answer_submitted")
  isCorrect       Boolean?     @map("is_correct")
  pointsAwarded   Int          @default(0) @map("points_awarded")
  answerTimeMs    Int          @map("answer_time_ms")
  submittedAt     DateTime     @default(now()) @map("submitted_at")

  @@unique([questionId, userId])
  @@index([questionId], map: "idx_quiz_answers_question_id")
  @@index([userId], map: "idx_quiz_answers_user_id")
  @@index([quizId], map: "idx_quiz_answers_quiz_id")
  @@map("quiz_answers")
}

enum QuizStatus {
  DRAFT
  WAITING
  ACTIVE
  FINISHED
  ABANDONED
}

enum QuizQuestionType {
  MCQ
  TRUE_FALSE
  SHORT_ANSWER
  POLL
  RATING
  MULTI_SELECT
  OPEN_ENDED
}

enum NetworkConnectionType {
  GUEST_SPEAKER
  GMEET_SESSION
  EVENT_JUDGE
  MENTOR
  INDUSTRY_PARTNER
  ALUMNI
  OTHER
}

enum NetworkStatus {
  PENDING
  VERIFIED
  REJECTED
}

// ──────────────── Playground ────────────────

model Execution {
  id         String          @id @default(uuid())
  userId     String          @map("user_id")
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  language   String
  code       String?         @db.Text
  outputText String?         @map("output_text") @db.Text
  executedAt DateTime        @default(now()) @map("executed_at")
  durationMs Int?            @map("duration_ms")
  status     ExecutionStatus @default(SUCCESS)

  @@index([userId, executedAt])
  @@index([executedAt])
  @@map("executions")
}

model UserPlaygroundPrefs {
  userId       String @id @map("user_id")
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme        String @default("dark")
  fontSize     Int    @default(14)
  keybinding   String @default("default") // 'vim' | 'emacs' | 'default'
  lastLanguage String @default("python") @map("last_language")

  @@map("user_playground_prefs")
}

model Snippet {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  language   String
  code       String   @db.Text
  isPublic   Boolean  @default(false) @map("is_public")
  shareToken String?  @unique @map("share_token")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([userId, createdAt])
  @@index([userId, updatedAt])
  @@index([shareToken])
  @@map("snippets")
}

model PlaygroundDailyUsage {
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  usageDate DateTime @map("usage_date") @db.Date
  count     Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([userId, usageDate])
  @@index([usageDate], map: "pdu_usage_date_idx")
  @@map("playground_daily_usage")
}

model PlaygroundLimitReset {
  id      String   @id @default(uuid())
  userId  String   @map("user_id")
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resetBy String   @map("reset_by")
  resetAt DateTime @default(now()) @map("reset_at")
  note    String?

  @@index([userId], map: "plr_user_id_idx")
  @@map("playground_limit_resets")
}

enum ExecutionStatus {
  SUCCESS
  ERROR
  TIMEOUT
}

// ──────────────── Signatories ────────────────

model Signatory {
  id           String   @id @default(cuid())
  name         String
  title        String   @default("Club President")
  signatureUrl String?  @map("signature_url") // Cloudinary URL or base64 data URI of transparent-bg PNG
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  certificatesAsPrimary Certificate[] @relation("PrimarySignatory")
  certificatesAsFaculty Certificate[] @relation("FacultySignatory")

  @@map("signatories")
}

// ──────────────── Certificate System ────────────────

enum CertType {
  PARTICIPATION
  COMPLETION
  WINNER
  SPEAKER
}

model Certificate {
  id     String @id @default(cuid())
  certId String @unique @map("cert_id") // Public human-readable ID e.g. "ABCD-EFGH-IJKL"

  recipientId String? @map("recipient_id")
  recipient   User?   @relation(fields: [recipientId], references: [id], onDelete: SetNull)

  recipientName  String @map("recipient_name")
  recipientEmail String @map("recipient_email")

  eventId   String? @map("event_id")
  event     Event?  @relation(fields: [eventId], references: [id], onDelete: SetNull)
  eventName String  @map("event_name")

  type        CertType
  position    String? // e.g. "1st Place" — only for WINNER type
  domain      String? // e.g. "Web Development"
  description String? // Optional description rendered on the certificate

  template String @default("gold") // gold | dark | white | emerald

  pdfUrl String? @map("pdf_url")

  // Signatory — snapshot denormalized at generation time for historical accuracy
  signatoryId       String?    @map("signatory_id")
  signatory         Signatory? @relation("PrimarySignatory", fields: [signatoryId], references: [id], onDelete: SetNull)
  signatoryName     String?    @map("signatory_name") // denormalized
  signatoryTitle    String?    @map("signatory_title") // denormalized
  signatoryImageUrl String?    @map("signatory_image_url") // denormalized (Cloudinary URL)

  // Faculty signatory — optional second signer
  facultySignatoryId       String?    @map("faculty_signatory_id")
  facultySignatory         Signatory? @relation("FacultySignatory", fields: [facultySignatoryId], references: [id], onDelete: SetNull)
  facultyName              String?    @map("faculty_name")
  facultyTitle             String?    @map("faculty_title")
  facultySignatoryImageUrl String?    @map("faculty_signatory_image_url")

  issuedBy String   @map("issued_by")
  issuedAt DateTime @default(now()) @map("issued_at")

  emailSent   Boolean   @default(false) @map("email_sent")
  emailSentAt DateTime? @map("email_sent_at")

  lastEmailResentAt DateTime? @map("last_email_resent_at")

  isRevoked     Boolean   @default(false) @map("is_revoked")
  revokedAt     DateTime? @map("revoked_at")
  revokedBy     String?   @map("revoked_by")
  revokedReason String?   @map("revoked_reason")

  viewCount Int @default(0) @map("view_count")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([recipientEmail, eventId, type], name: "unique_cert_per_event")
  @@index([recipientId])
  @@index([eventId])
  @@index([certId])
  @@index([recipientEmail])
  @@index([eventId, issuedAt])
  @@map("certificates")
}

model Credit {
  id           String      @id @default(uuid())
  title        String
  description  String?     @db.Text
  category     String
  teamMemberId String?     @map("team_member_id")
  teamMember   TeamMember? @relation(fields: [teamMemberId], references: [id], onDelete: SetNull)
  order        Int         @default(0)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  @@index([category, order])
  @@index([teamMemberId])
  @@map("credits")
}
