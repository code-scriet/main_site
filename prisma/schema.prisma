  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, qotdId])
  @@index([qotdId])
  @@index([userId, timestamp])
  @@index([timestamp])
  @@map("qotd_submissions")
}

model AuditLog {
  id        String   @id @default(uuid())
